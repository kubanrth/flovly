// PMS domain schema — System Zarządzania Projektami
// Hosting: Supabase Postgres | ORM: Prisma 7
// Tenancy: workspaceId denormalized on user-content; authorization in Route Handlers.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (Auth.js v5 — Prisma adapter compatible)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  avatarUrl     String?
  passwordHash  String?
  timezone      String    @default("Europe/Warsaw")
  locale        String    @default("pl")
  isSuperAdmin  Boolean   @default(false)
  isBanned      Boolean   @default(false)
  lastSeenAt    DateTime?
  totpSecret    String?
  totpEnabledAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts           Account[]
  sessions           Session[]
  memberships        WorkspaceMembership[]
  // F12-K8: per-board access list. Independent of workspace membership.
  boardMemberships   BoardMembership[]
  invitationsSent    Invitation[]          @relation("InvitationInviter")
  createdWorkspaces  Workspace[]           @relation("WorkspaceOwner")
  createdBoards      Board[]               @relation("BoardCreator")
  createdTasks       Task[]                @relation("TaskCreator")
  assignedTasks      TaskAssignee[]
  createdMilestones  Milestone[]           @relation("MilestoneCreator")
  assignedMilestones Milestone[]           @relation("MilestoneAssignee")
  uploadedFiles      Attachment[]
  comments           Comment[]
  mentions           CommentMention[]
  auditLogs          AuditLog[]            @relation("AuditActor")
  globalAuditLogs    GlobalAuditLog[]      @relation("GlobalAuditActor")
  adminAuditLogs     AdminAuditLog[]       @relation("AdminAuditActor")
  notifications      Notification[]
  createdCanvases    ProcessCanvas[]       @relation("CanvasCreator")
  createdTags        Tag[]                 @relation("TagCreator")
  totpRecoveryCodes  TotpRecoveryCode[]
  todoFolders        TodoFolder[]
  todoLists          TodoList[]
  todoItems          TodoItem[]
  noteFolders        NoteFolder[]
  notes              Note[]
  createdReminders   PersonalReminder[]    @relation("ReminderCreator")
  receivedReminders  PersonalReminder[]    @relation("ReminderRecipient")
  pollVotes          TaskPollVote[]
  authoredPolls      TaskPoll[]            @relation("PollAuthor")
  editedWikiPages    WikiPage[]            @relation("WikiEditor")
  // F11-20: support tickets (zgłoszenia w ramach workspace).
  reportedTickets    SupportTicket[]       @relation("SupportReporter")
  assignedTickets    SupportTicket[]       @relation("SupportAssignee")
  // F12-K25: support attachment uploader.
  supportAttachments SupportTicketAttachment[] @relation("SupportAttachmentUploader")
  // F11-21: creative briefs created by user.
  createdBriefs      CreativeBrief[]       @relation("BriefCreator")
  // F11-22: workspace-level calendar events created by user.
  createdEvents      WorkspaceEvent[]      @relation("EventCreator")

  @@index([isBanned])
  @@index([lastSeenAt])
}

model TotpRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Workspaces & Access
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

model Workspace {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  description      String?
  avatarUrl        String?
  ownerId          String
  storageUsedBytes BigInt    @default(0)
  // F8: per-workspace set of enabled board views (see ViewType).
  // Stored as JSON array of enum names so we can filter ViewSwitcher
  // without joining BoardView. Default = all five.
  enabledViews     Json      @default("[\"TABLE\",\"KANBAN\",\"ROADMAP\",\"GANTT\",\"WHITEBOARD\"]")
  // F12-K51: kolejność workspace'ów na liście /workspaces. Float żeby
  // przy reorderze móc wstawić między dowolne 2 elementy bez przepisywania
  // całej kolumny (jak w TodoItem.order, Task.rowOrder).
  order            Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  owner                User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  memberships          WorkspaceMembership[]
  invitations          Invitation[]
  boards               Board[]
  canvases             ProcessCanvas[]
  tags                 Tag[]
  tasks                Task[]
  milestones           Milestone[]
  auditLogs            AuditLog[]
  wikiPage             WikiPage?
  firefliesIntegration FirefliesIntegration?
  // F11-20: support tickets per-workspace.
  supportTickets       SupportTicket[]
  // F11-21: creative briefs per-workspace.
  creativeBriefs       CreativeBrief[]
  // F11-22: workspace-level calendar events.
  events               WorkspaceEvent[]
  // F12-K34: dzienne backupy — JSON snapshot wszystkich workspace-scoped
  // tabel, dostępny dla superadmina w /admin/backups.
  backups              WorkspaceBackup[]

  @@index([ownerId])
  @@index([deletedAt])
}

model WorkspaceMembership {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Invitation {
  id          String    @id @default(cuid())
  workspaceId String
  // F12-K8: optional board scope. When non-null, redeeming the invite
  // creates BoardMembership for that board (in addition to a workspace
  // membership if the user isn't already a member). Null = workspace-only.
  boardId     String?
  email       String
  role        Role      @default(MEMBER)
  token       String    @unique
  inviterId   String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board     Board?    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  inviter   User      @relation("InvitationInviter", fields: [inviterId], references: [id])

  // One pending invite per email/workspace — re-inviting same email
  // updates the existing row (incl. flipping scope between workspace
  // and board). Avoids ambiguous duplicate invites.
  @@unique([workspaceId, email])
  @@index([token])
  @@index([boardId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Boards, Views, Status columns
// ─────────────────────────────────────────────────────────────────────────────

enum ViewType {
  TABLE
  KANBAN
  ROADMAP
  GANTT
  WHITEBOARD
}

// F12-K8: per-board visibility. PUBLIC = open to everyone in the workspace
// (legacy default — every existing board migrates to PUBLIC). PRIVATE =
// only workspace ADMINs + explicit BoardMembership entries can access.
enum Visibility {
  PUBLIC
  PRIVATE
}

model Board {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  description String?
  // F12-K57: 'Opis ogólny' — per-board rich-text wiki-like overview.
  // Tiptap doc shape. Pokazywany jako widok 'Opis' w ViewSwitcherze
  // obok Tabela/Kanban/Roadmap/Gantt/Whiteboard.
  overviewJson Json?
  creatorId   String
  visibility  Visibility @default(PUBLIC)
  // F12-K51: kolejność tablic w danym workspace na overview page.
  order       Float      @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator       User              @relation("BoardCreator", fields: [creatorId], references: [id])
  memberships   BoardMembership[]
  invitations   Invitation[]
  views         BoardView[]
  statusColumns StatusColumn[]
  customColumns TableColumn[]
  tasks         Task[]
  milestones    Milestone[]
  links         BoardLink[]
  linkFolders   LinkFolder[]
  canvas        ProcessCanvas?

  @@index([workspaceId])
  @@index([deletedAt])
}

// F12-K8: per-board access list. Only consulted when Board.visibility =
// PRIVATE. Workspace ADMINs bypass this regardless. Role here is
// duplicated from WorkspaceMembership so a user can have a different
// (typically lower) role per board than they have at workspace level.
model BoardMembership {
  id       String   @id @default(cuid())
  boardId  String
  userId   String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

// F8: removed @@unique([boardId, type]) — a board may now have multiple
// views of the same type (e.g. two Kanbans with different filters).
// `name` is optional for the default per-type view (falls back to the
// localized type label in UI); required for user-created extra views.
model BoardView {
  id         String   @id @default(cuid())
  boardId    String
  type       ViewType
  name       String?
  configJson Json     @default("{}")
  background Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, type])
}

enum BoardLinkKind {
  DRIVE
  SHEETS
  DOCS
  SLIDES
  OTHER
}

// F8: original flat-link-chips model. Still used by boards that haven't
// migrated to the folder-table UX yet; new rows go to LinkFolder below.
model BoardLink {
  id        String        @id @default(cuid())
  boardId   String
  kind      BoardLinkKind
  url       String
  label     String?
  order     Int           @default(0)
  createdAt DateTime      @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, order])
}

// F9-12: "Folder linków" — a named container with a user-defined table
// (columns + rows). Klient chce organized spreadsheets of links, not
// flat chips. Columns are stored as separate rows (LinkFolderColumn)
// and each row's cells are keyed by columnId (LinkFolderCellValue).
model LinkFolder {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board   Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  columns LinkFolderColumn[]
  rows    LinkFolderRow[]

  @@index([boardId, order])
}

model LinkFolderColumn {
  id        String   @id @default(cuid())
  folderId  String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  folder LinkFolder            @relation(fields: [folderId], references: [id], onDelete: Cascade)
  cells  LinkFolderCellValue[]

  @@index([folderId, order])
}

model LinkFolderRow {
  id        String   @id @default(cuid())
  folderId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder LinkFolder            @relation(fields: [folderId], references: [id], onDelete: Cascade)
  cells  LinkFolderCellValue[]

  @@index([folderId, order])
}

model LinkFolderCellValue {
  rowId     String
  columnId  String
  valueText String?
  updatedAt DateTime @updatedAt

  row    LinkFolderRow    @relation(fields: [rowId], references: [id], onDelete: Cascade)
  column LinkFolderColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@id([rowId, columnId])
  @@index([columnId])
}

// F9-07 + F10-A: Airtable-style fields. `type` is one of the FieldType
// values defined in lib/table-fields.ts (TEXT, NUMBER, DATE, SINGLE_SELECT,
// MULTI_SELECT, URL, EMAIL, PHONE, RATING, USER, CHECKBOX, LONG_TEXT,
// CREATED_TIME, LAST_MODIFIED_TIME, CREATED_BY, AUTO_NUMBER).
// `options` carries type-specific config: select option list with colors,
// number format/precision, rating max/icon, date includeTime, etc.
model TableColumn {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  type      String   @default("TEXT")
  options   Json?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board  Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  values TaskCustomValue[]

  @@index([boardId, order])
}

model TaskCustomValue {
  taskId    String
  columnId  String
  // Text payload — stringified to keep the schema flat. When the column
  // type is anything other than TEXT we parse on read.
  valueText String?
  updatedAt DateTime @updatedAt

  task   Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  column TableColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@id([taskId, columnId])
  @@index([columnId])
}

model StatusColumn {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  colorHex  String   @default("#64748B")
  order     Int
  createdAt DateTime @default(now())

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId, order])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tasks, Milestones, Tags
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id                    String    @id @default(cuid())
  workspaceId           String
  boardId               String
  // F12-K57: ludzki ID zadania per-workspace (1, 2, 3...). Wyświetlany
  // w UI zamiast obciętego cuid'a (np. 'CERDPC2S'). Backfill istniejących
  // wierszy w migracji — kolejność po createdAt.
  displayId             Int       @default(0)
  statusColumnId        String?
  milestoneId           String?
  creatorId             String
  title                 String
  descriptionJson       Json?
  startAt               DateTime?
  stopAt                DateTime?
  // F8: user-configured reminder offset resolved to absolute timestamp
  // at save-time. Cron job `/api/cron/send-reminders` sweeps rows where
  // reminderAt <= now() AND reminderSentAt IS NULL.
  reminderAt            DateTime?
  reminderSentAt        DateTime?
  // F11-17: recurring tasks. Template tasks have `recurrenceRule` set;
  // cron `/api/cron/spawn-recurring` reads them daily and creates a
  // child Task with `recurrenceParentId` pointing back at the template.
  // Rule shape (Json): `{ freq: "daily" | "weekly" | "monthly", day?: number }`.
  // - daily: every day
  // - weekly: `day` = 0..6 (Sun..Sat)
  // - monthly: `day` = 1..31 (clamped to month end)
  recurrenceRule        Json?
  recurrenceParentId    String?
  recurrenceLastSpawnAt DateTime?
  // F12-K40: per-task time tracking. Klient: 'do każdego zadania muszę
  // dodać start/stop'. Trzy stany:
  //   - Idle:      timerStartedAt=null, timerCompletedAt=null  → "Rozpocznij"
  //   - Running:   timerStartedAt set                          → "Zatrzymaj"+"Zakończ"
  //   - Completed: timerCompletedAt set                        → locked, brak przycisków
  // Akumulator zachowuje się przez pause/resume cykle.
  timeTrackedSeconds    Int       @default(0)
  timerStartedAt        DateTime?
  timerCompletedAt      DateTime?
  rowOrder              Float     @default(0)
  version               Int       @default(1)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board        Board                 @relation(fields: [boardId], references: [id], onDelete: Cascade)
  statusColumn StatusColumn?         @relation(fields: [statusColumnId], references: [id])
  milestone    Milestone?            @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  creator      User                  @relation("TaskCreator", fields: [creatorId], references: [id])
  assignees    TaskAssignee[]
  tags         TaskTag[]
  comments     Comment[]
  attachments  Attachment[]
  nodeLinks    ProcessNodeTaskLink[]
  subtasks     Subtask[]
  poll         TaskPoll?
  customValues TaskCustomValue[]

  @@index([boardId, statusColumnId, rowOrder])
  @@index([boardId, updatedAt(sort: Desc)])
  @@index([workspaceId, deletedAt])
  @@index([milestoneId])
  @@index([reminderAt, reminderSentAt])
  // F11-17: cron query — find tasks with recurrence not spawned today.
  @@index([recurrenceLastSpawnAt])
}

// F11-22 (#22): kalendarz na poziomie workspace — pokazuje zadania
// + niestandardowe wydarzenia (spotkania / deadliny / off-task work).
model WorkspaceEvent {
  id          String    @id @default(cuid())
  workspaceId String
  creatorId   String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean   @default(false)
  // Hex color (#RRGGBB). Default brand purple.
  color       String    @default("#7B68EE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("EventCreator", fields: [creatorId], references: [id])

  @@index([workspaceId, deletedAt])
  @@index([startAt])
}

// F11-21 (#25): Creative brief — strukturalny dokument projektowy
// (przykład z ClickUp). Tiptap doc z prefilled template'em sekcji
// (Cele / Grupa docelowa / Deliverables / Brand / Referencje / Timeline).
enum CreativeBriefStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ARCHIVED
}

model CreativeBrief {
  id          String              @id @default(cuid())
  workspaceId String
  creatorId   String
  title       String
  contentJson Json?
  status      CreativeBriefStatus @default(DRAFT)
  emoji       String?
  headerColor String?             @default("#7B68EE")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("BriefCreator", fields: [creatorId], references: [id])

  @@index([workspaceId, deletedAt])
  @@index([creatorId])
}

// F11-20 (#23): support tickets — internal helpdesk. Każdy member
// workspace'u może zgłosić temat wymagający supportu; admini widzą
// wszystkie i odpowiadają.
enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id          String                @id @default(cuid())
  workspaceId String
  reporterId  String
  assigneeId  String?
  title       String
  description String                @db.Text
  status      SupportTicketStatus   @default(OPEN)
  priority    SupportTicketPriority @default(MEDIUM)
  // F12-K11: opcjonalny deadline + flaga "NATYCHMIAST". Reporter
  // ustawia jedno z tych (lub żadne) przy tworzeniu zgłoszenia;
  // isUrgent=true sygnalizuje "zrób natychmiast" i UI nadpisuje
  // wyświetlanie dueAt — pokazuje czerwony badge "NATYCHMIAST".
  dueAt       DateTime?
  isUrgent    Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  resolvedAt  DateTime?

  workspace   Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reporter    User                      @relation("SupportReporter", fields: [reporterId], references: [id])
  assignee    User?                     @relation("SupportAssignee", fields: [assigneeId], references: [id])
  attachments SupportTicketAttachment[]

  @@index([workspaceId, status])
  @@index([reporterId])
}

// F8: simple in-task checklist. Separate from Task because we reorder
// often and don't want to bump `Task.version` for every tick.
model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  order     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, order])
}

// F8: one poll per task. Author defines question + 2-5 options;
// members cast exactly one vote per poll (enforced by @@id on Vote).
model TaskPoll {
  id        String    @id @default(cuid())
  taskId    String    @unique
  question  String
  authorId  String
  createdAt DateTime  @default(now())
  closedAt  DateTime?

  task    Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  User             @relation("PollAuthor", fields: [authorId], references: [id])
  options TaskPollOption[]
  votes   TaskPollVote[]

  @@index([taskId])
}

model TaskPollOption {
  id     String @id @default(cuid())
  pollId String
  label  String
  order  Int    @default(0)

  poll  TaskPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes TaskPollVote[]

  @@index([pollId, order])
}

model TaskPollVote {
  pollId    String
  userId    String
  optionId  String
  createdAt DateTime @default(now())

  poll   TaskPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option TaskPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([pollId, userId])
  @@index([optionId])
  @@index([userId])
}

model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId, taskId])
}

model Tag {
  // workspaceId NULL = globalny (admin-created)
  id          String   @id @default(cuid())
  workspaceId String?
  name        String
  colorHex    String
  creatorId   String
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User       @relation("TagCreator", fields: [creatorId], references: [id])
  tasks     TaskTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

model Milestone {
  id              String    @id @default(cuid())
  workspaceId     String
  boardId         String
  creatorId       String
  assigneeId      String?
  title           String
  descriptionJson Json?
  startAt         DateTime
  stopAt          DateTime
  orderIndex      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  creator   User      @relation("MilestoneCreator", fields: [creatorId], references: [id])
  assignee  User?     @relation("MilestoneAssignee", fields: [assigneeId], references: [id])
  tasks     Task[]

  @@index([boardId, orderIndex])
  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Comments, Attachments, Notifications
// ─────────────────────────────────────────────────────────────────────────────

model Comment {
  id        String    @id @default(cuid())
  taskId    String
  authorId  String
  parentId  String?
  bodyJson  Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  task     Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author   User             @relation(fields: [authorId], references: [id])
  parent   Comment?         @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[]        @relation("CommentThread")
  mentions CommentMention[]

  @@index([taskId, createdAt])
}

model CommentMention {
  commentId       String
  mentionedUserId String
  createdAt       DateTime @default(now())

  comment       Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser User    @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@id([commentId, mentionedUserId])
  @@index([mentionedUserId])
}

model Attachment {
  id         String    @id @default(cuid())
  taskId     String
  uploaderId String
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploaderId], references: [id])

  @@index([taskId])
}

// F12-K25: załączniki dla support ticketów (oddzielny model od
// Attachment'a do task'ów — chcemy odrębną retention policy + cascade
// delete na poziomie ticketu). Storage path: w/<wid>/support/<tid>/...
model SupportTicketAttachment {
  id         String    @id @default(cuid())
  ticketId   String
  uploaderId String
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime  @default(now())

  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploader User          @relation("SupportAttachmentUploader", fields: [uploaderId], references: [id])

  @@index([ticketId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  // F12-K35: notatka usera doklejona do auto-generowanej notyfikacji.
  // Klient: 'zapisane powiadomienie musi mieć możliwość edycji'. System
  // generuje treść z payload'u, ale user może dopisać własną adnotację
  // (priorytet, kontekst, TODO) widoczną w inbox'ie.
  userNote  String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit logs
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  // Polymorphic: objectId can reference Task, Milestone, Board, Workspace, etc.
  // No FK constraint — validate objectType in application layer.
  id          String   @id @default(cuid())
  workspaceId String
  objectType  String
  objectId    String
  actorId     String?
  action      String
  diff        Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation("AuditActor", fields: [actorId], references: [id])

  @@index([workspaceId, objectType, objectId, createdAt(sort: Desc)])
  @@index([actorId])
}

model GlobalAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorIp    String?
  endpoint   String
  method     String
  statusCode Int
  errorType  String?
  latencyMs  Int?
  createdAt  DateTime @default(now())

  actor User? @relation("GlobalAuditActor", fields: [actorId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([statusCode])
  @@index([actorId])
}

// Cross-workspace admin actions (ban, force-delete, restore, etc.). Kept
// separate from AuditLog because those entries FK to Workspace, which
// doesn't apply to system-level operations. `actorEmail` is denormalised
// so the trail survives even if the actor's User row is later
// soft-deleted or masked.
model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorEmail  String
  action      String
  targetType  String
  targetId    String
  targetLabel String?
  diff        Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AdminAuditActor", fields: [actorId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([actorId])
  @@index([action])
}

// ─────────────────────────────────────────────────────────────────────────────
// Whiteboard (Process Canvas)
// ─────────────────────────────────────────────────────────────────────────────

model ProcessCanvas {
  id          String    @id @default(cuid())
  workspaceId String
  // F8: whiteboards migrated to board-level. `boardId` is nullable
  // only for legacy workspace-level canvases created before F8; new
  // canvases always set it. One canvas per board (enforced by @@unique).
  boardId     String?   @unique
  name        String
  creatorId   String
  yjsState    Bytes?
  background  Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  board     Board?          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  creator   User            @relation("CanvasCreator", fields: [creatorId], references: [id])
  nodes     ProcessNode[]
  edges     ProcessEdge[]
  // F10-W: pen-tool strokes captured by the user (Mural-style drawing).
  strokes   ProcessStroke[]

  @@index([workspaceId])
}

enum NodeShape {
  RECTANGLE
  DIAMOND
  CIRCLE
  ICON
  // F8b: Whimsical-lite additions.
  STICKY
  FRAME
  // F10-W (Mural-feel): plain text — no fill, no border, just sized text.
  TEXT
  // F12-K37: image node — colorHex pole nieużywane, dataJson trzyma
  // { imagePath: string } (storage key w bucket'cie attachments).
  IMAGE
}

// F10-W: free-drawing strokes (pen tool) on a canvas. Each row = one
// continuous stroke captured between pointerdown and pointerup. Points
// stored as JSON [{x,y}, …] in canvas (world) coordinates so they pan
// and zoom with the rest of the content.
model ProcessStroke {
  id        String   @id @default(cuid())
  canvasId  String
  colorHex  String   @default("#1F2937")
  size      Int      @default(2)
  points    Json
  createdAt DateTime @default(now())

  canvas ProcessCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  @@index([canvasId])
}

model ProcessNode {
  id        String    @id @default(cuid())
  canvasId  String
  shape     NodeShape @default(RECTANGLE)
  label     String?
  iconName  String?
  x         Float
  y         Float
  width     Float     @default(160)
  height    Float     @default(80)
  colorHex  String    @default("#FFFFFF")
  dataJson  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  canvas    ProcessCanvas         @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  outEdges  ProcessEdge[]         @relation("EdgeFrom")
  inEdges   ProcessEdge[]         @relation("EdgeTo")
  taskLinks ProcessNodeTaskLink[]

  @@index([canvasId])
}

model ProcessEdge {
  id         String   @id @default(cuid())
  canvasId   String
  fromNodeId String
  toNodeId   String
  label      String?
  style      String   @default("solid")
  // F8b: end marker of the connector. One of: "arrow" (default), "none",
  // "diamond", "circle". String column so we can add more variants without
  // a migration.
  endStyle   String   @default("arrow")
  createdAt  DateTime @default(now())

  canvas   ProcessCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  fromNode ProcessNode   @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   ProcessNode   @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([canvasId])
}

model ProcessNodeTaskLink {
  nodeId String
  taskId String

  node ProcessNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  task Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([nodeId, taskId])
  @@index([taskId])
}

// ─────────────────────────────────────────────────────────────────────────────
// F8: Personal TODO module (private per-user, not linked to any board)
// ─────────────────────────────────────────────────────────────────────────────

// Self-referential tree — parentId NULL = root. Cascade on parent delete
// means deleting a folder removes its subtree (lists moved to trash/root
// by application layer if we want soft behaviour later).
model TodoFolder {
  id        String   @id @default(cuid())
  userId    String
  parentId  String?
  name      String
  order     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   TodoFolder?  @relation("TodoFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children TodoFolder[] @relation("TodoFolderTree")
  lists    TodoList[]

  @@index([userId, parentId, order])
}

model TodoList {
  id        String   @id @default(cuid())
  userId    String
  folderId  String?
  name      String
  order     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder TodoFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
  items  TodoItem[]

  @@index([userId, folderId, order])
}

model TodoItem {
  id             String    @id @default(cuid())
  listId         String
  userId         String
  content        String
  completed      Boolean   @default(false)
  dueDate        DateTime?
  order          Float     @default(0)
  // F8c: Microsoft To Do parity.
  // important — star / "Ważne" smart list feeds off this.
  // myDayAt    — timestamp when user added it to "My Day". Shown in the
  //              Mój dzień smart list when `myDayAt >= todayStart`; auto-
  //              drops out on the next calendar day.
  // notes      — free-form long text under the title.
  // reminderAt / reminderSentAt — handled by the same cron that sends
  //              Task reminders (see /api/cron/send-reminders).
  important      Boolean   @default(false)
  myDayAt        DateTime?
  notes          String?
  reminderAt     DateTime?
  reminderSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  list  TodoList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps TodoStep[]

  @@index([listId, order])
  @@index([userId, dueDate])
  @@index([userId, important])
  @@index([userId, myDayAt])
  @@index([reminderAt, reminderSentAt])
}

// F8c: Steps inside a TodoItem (nested checklist, matching MS To Do's
// "Kroki"). Separate table so we can reorder / tick individual steps
// without rewriting the parent row.
model TodoStep {
  id        String   @id @default(cuid())
  itemId    String
  title     String
  // F12-K28: notes per pod-zadanie. Klient zażądał osobnych opisów
  // dla każdego subtaska (parent TodoItem już ma `notes`). Optional —
  // pusty string i null są równoważne na poziomie UI.
  notes     String?  @db.Text
  completed Boolean  @default(false)
  order     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item TodoItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, order])
}

// ─────────────────────────────────────────────────────────────────────────────
// F9-15: Notatnik — prywatny per-user moduł jak Apple Notes. Folder
// zawiera listę notatek; notatka ma tytuł + długi tekst (plain dla
// MVP; można przełączyć na Tiptap w przyszłości).
// ─────────────────────────────────────────────────────────────────────────────

model NoteFolder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  order     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes Note[]

  @@index([userId, order])
}

model Note {
  id          String    @id @default(cuid())
  userId      String
  folderId    String?
  title       String    @default("Nowa notatka")
  content     String    @default("")
  // F11-23 (#14): rich text content (Tiptap JSON). `content` plain
  // text retained as fallback + search-friendly snippet source.
  contentJson Json?
  pinned      Boolean   @default(false)
  // F11-23: soft delete — moves note to Kosz, recoverable.
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder NoteFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt(sort: Desc)])
  @@index([folderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// F9-16: Przypomnienia — lightweight reminders separate from Task/TodoItem
// reminders. Creator decides who gets the pop-up. Recipient can dismiss
// (hide own copy), but only the creator can permanently delete it.
// ─────────────────────────────────────────────────────────────────────────────

model PersonalReminder {
  id          String    @id @default(cuid())
  creatorId   String
  recipientId String
  title       String
  body        String?
  dueAt       DateTime
  // Set when the recipient dismissed the bubble (X on popup). Creator
  // can't see the dismissed-by-recipient state; dismissal only hides the
  // popup for the recipient, doesn't delete the row.
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator   User @relation("ReminderCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  recipient User @relation("ReminderRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, dismissedAt, dueAt])
  @@index([creatorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// F8: Wiki (one "O projekcie" page per workspace, Tiptap JSON content)
// ─────────────────────────────────────────────────────────────────────────────

model WikiPage {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  title       String   @default("O projekcie")
  contentJson Json?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updatedBy User?     @relation("WikiEditor", fields: [updatedById], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// F8: FireFlies integration — per-workspace webhook + API key
// ─────────────────────────────────────────────────────────────────────────────

model FirefliesIntegration {
  id             String   @id @default(cuid())
  workspaceId    String   @unique
  apiKey         String
  webhookSecret  String
  defaultBoardId String?
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// System flags (admin maintenance controls)
// ─────────────────────────────────────────────────────────────────────────────

model SystemFlag {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// F12-K34: dzienne snapshoty całego workspace'u. Cron `/api/cron/workspace-backup`
// uderza raz dziennie i serializuje wszystkie workspace-scoped tabele do
// JSON-a, który ląduje w Supabase Storage (bucket `attachments`,
// key `w/<wid>/backups/<dayKey>.json`). Ten model jest tylko indexem —
// pozwala szybko wylistować backupy w `/admin/backups` bez listingu storage'u.
model WorkspaceBackup {
  id          String   @id @default(cuid())
  workspaceId String
  // YYYY-MM-DD w strefie Europe/Warsaw — unique key (1 backup/dzień).
  dayKey      String
  storageKey  String
  sizeBytes   Int
  // Shallow countery per-tabela ({ boards: 5, tasks: 47, … }) do quick-stats
  // w UI panelu admina — bez pobierania pełnego JSON-a.
  modelCounts Json
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, dayKey])
  @@index([workspaceId, createdAt(sort: Desc)])
}
