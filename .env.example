# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit credentials.

# ─────────────── Database (Supabase Postgres) ───────────────
# Use POOLER URL for runtime (serverless-friendly).
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use DIRECT URL for migrations (prisma migrate dev/deploy).
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─────────────── Supabase (Storage + Realtime + Auth SDK) ───────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
# New key format (Supabase migrated away from anon/service_role in 2025)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."

# ─────────────── Auth.js ───────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
# In production set to https://your-domain.com
NEXTAUTH_URL="http://localhost:3100"

# ─────────────── Email (Resend) ───────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="DANIELOS PMS <no-reply@example.com>"
# Pełny URL produkcyjny (BEZ trailing slash). Używany jako prefix w emailach
# (link do otwartego zadania) + walidacja redirectTo w Auth.js.
# Lokalnie: http://localhost:3100. Prod: https://twoja-domena.com.
APP_BASE_URL="http://localhost:3100"

# ─────────────── Cron jobs (Vercel Cron) ───────────────
# Bearer token używany przez /api/cron/* route handlery żeby gateować
# dostęp (Vercel Cron wysyła ten header automatycznie). Wygeneruj
# losowy 32+ bajtowy string: `openssl rand -hex 32`. Bez tego ENV-vary
# wszystkie cron endpointy zwracają 401 silently → reminder'y, daily
# backupy i recurring tasks PRZESTAJĄ DZIAŁAĆ. Wymagane na produkcji.
CRON_SECRET=""

# ─────────────── Rate limiting (Upstash Redis) ───────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────── Observability (Sentry) ───────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ─────────────── Czesiek AI (LLM provider) ───────────────
# Primary: Groq — free tier do 14400 req/dzień, Llama 3.3 70B Versatile.
# Wygeneruj klucz na console.groq.com → API Keys. Bez tego klucza Czesiek
# zwróci 503 dopóki nie ustawisz OPENAI_API_KEY jako fallback.
GROQ_API_KEY=""
# Optional fallback gdy Groq jest down / rate-limited. Bez tego klucza
# Czesiek zawodzi cicho gdy Groq nie odpowiada. Płatne (~$6/mc przy 10 user'ach).
OPENAI_API_KEY=""
